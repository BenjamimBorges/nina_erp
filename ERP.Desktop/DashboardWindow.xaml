<Window x:Class="ERP.Desktop.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nina ERP — Dashboard"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- Barra superior -->
        <Border DockPanel.Dock="Top" Background="#4f46e5" Padding="16,10">
            <DockPanel>
                <TextBlock Text="Nina ERP" FontSize="18" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>
                <Button Content="Sair" DockPanel.Dock="Right"
                        Margin="0,0,12,0" Padding="10,4"
                        Background="#6d5fd4" Foreground="White" BorderThickness="0"
                        Click="OnLogoutClicked"/>
                <TextBlock Text="{Binding UserGreeting}" DockPanel.Dock="Right"
                           Foreground="#c7d2fe" VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- Abas -->
        <TabControl Margin="8">
            <TabItem Header="Clientes">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Atualizar" Click="OnRefreshClients" Padding="10,5"/>
                    </StackPanel>
                    <DataGrid x:Name="ClientsGrid" AutoGenerateColumns="False"
                              IsReadOnly="True" GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#F9F9FF">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Documento" Binding="{Binding Document}" Width="140"/>
                            <DataGridTextColumn Header="E-mail" Binding="{Binding Email}" Width="200"/>
                            <DataGridTextColumn Header="Telefone" Binding="{Binding Phone}" Width="120"/>
                            <DataGridTextColumn Header="Empresa" Binding="{Binding CompanyName}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Produtos">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Atualizar" Click="OnRefreshProducts" Padding="10,5"/>
                    </StackPanel>
                    <DataGrid x:Name="ProductsGrid" AutoGenerateColumns="False"
                              IsReadOnly="True" GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#F9FFF9">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="120"/>
                            <DataGridTextColumn Header="Descrição" Binding="{Binding Description}" Width="200"/>
                            <DataGridTextColumn Header="Preço" Binding="{Binding Price, StringFormat=C2}" Width="100"/>
                            <DataGridTextColumn Header="Empresa" Binding="{Binding CompanyName}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Estoque">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Atualizar" Click="OnRefreshStocks" Padding="10,5"/>
                    </StackPanel>
                    <DataGrid x:Name="StocksGrid" AutoGenerateColumns="False"
                              IsReadOnly="True" GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#FFFFF9">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Produto" Binding="{Binding ProductName}" Width="200"/>
                            <DataGridTextColumn Header="Quantidade" Binding="{Binding Quantity}" Width="100"/>
                            <DataGridTextColumn Header="Localização" Binding="{Binding Location}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
