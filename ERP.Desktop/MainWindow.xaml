<Window x:Class="ERP.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ERP.Desktop.Converters"
        xmlns:beh="clr-namespace:ERP.Desktop.Behaviors"
        Title="Nina ERP — Login"
        Height="420" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBooleanConverter x:Key="InverseBool"/>
        <conv:StringToVisibilityConverter x:Key="StringToVis"/>
        <Storyboard x:Key="SpinAnimation" RepeatBehavior="Forever">
            <DoubleAnimation
                Storyboard.TargetName="SpinnerRect"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                From="0" To="360" Duration="0:0:1"/>
        </Storyboard>
    </Window.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <TextBlock Text="Nina ERP" FontSize="26" FontWeight="Bold" Foreground="#1a1a2e"/>
        <TextBlock Grid.Row="1" Text="Sistema Integrado de Gestão Empresarial"
                   FontSize="12" Foreground="#888" Margin="0,4,0,24"/>

        <!-- Formulário -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Usuário" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,4"/>
            <TextBox x:Name="UsernameBox"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Height="36" Padding="10,8" Margin="0,0,0,14"
                     IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}"/>

            <TextBlock Text="Senha" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordBox"
                         Height="36" Padding="10,8"
                         beh:PasswordBoxBehavior.IsLoading="{Binding IsLoading}"
                         PasswordChanged="PasswordBox_PasswordChanged"/>
        </StackPanel>

        <!-- Botão -->
        <Button Grid.Row="3" Content="Entrar"
                Width="120" Height="40" HorizontalAlignment="Left" Margin="0,20,0,0"
                Click="OnLoginClicked"
                IsEnabled="{Binding IsFormValid}"
                Background="#4f46e5" Foreground="White"
                FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>

        <!-- Mensagem de status (só aparece quando não vazia) -->
        <TextBlock Grid.Row="4"
                   Text="{Binding StatusMessage}"
                   Foreground="#c0392b" FontSize="12"
                   Margin="0,12,0,0" TextWrapping="Wrap"
                   Visibility="{Binding StatusMessage, Converter={StaticResource StringToVis}}"/>

        <!-- Spinner de loading (separado do status) -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,8,0,0"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <Rectangle x:Name="SpinnerRect"
                       Width="14" Height="14" Margin="0,0,8,0"
                       Fill="#4f46e5" RenderTransformOrigin="0.5,0.5">
                <Rectangle.RenderTransform>
                    <RotateTransform Angle="0"/>
                </Rectangle.RenderTransform>
                <Rectangle.Triggers>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard Storyboard="{StaticResource SpinAnimation}"/>
                    </EventTrigger>
                </Rectangle.Triggers>
            </Rectangle>
            <TextBlock Text="Conectando ao servidor..."
                       Foreground="#4f46e5" FontSize="12" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
