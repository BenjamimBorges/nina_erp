<Window x:Class="ERP.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nina ERP — Login"
        Height="360" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="#F5F5F5">
        <Border Background="White" CornerRadius="12" Margin="40"
                Effect="{x:Null}" Padding="32">
            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="Nina ERP" FontSize="26" FontWeight="Bold"
                           Foreground="#1a1a2e" HorizontalAlignment="Center"/>
                <TextBlock Text="Faça login para continuar" FontSize="13"
                           Foreground="#888" HorizontalAlignment="Center" Margin="0,4,0,24"/>

                <TextBlock Text="Usuário" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                <TextBox x:Name="UsernameBox"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14" Padding="8" Height="36"
                         BorderBrush="#DDD" BorderThickness="1"/>

                <TextBlock Text="Senha" FontSize="12" Foreground="#555" Margin="0,14,0,4"/>
                <PasswordBox x:Name="PasswordBox" FontSize="14" Padding="8" Height="36"
                             BorderBrush="#DDD" BorderThickness="1"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <Button Content="{Binding IsBusy, Converter={x:Null}}"
                        x:Name="LoginButton"
                        Height="40" Margin="0,20,0,0"
                        Background="#4f46e5" Foreground="White"
                        FontSize="14" FontWeight="SemiBold" BorderThickness="0"
                        Click="OnLoginClicked"
                        IsEnabled="{Binding IsBusy, Converter={x:Null}}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="Entrar"/>
                            <Setter Property="IsEnabled" Value="True"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Content" Value="Aguarde..."/>
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock Text="{Binding StatusMessage}" Foreground="#c0392b"
                           FontSize="12" Margin="0,12,0,0"
                           TextWrapping="Wrap" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
